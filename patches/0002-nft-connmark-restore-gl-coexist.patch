# GL.iNet: PREROUTING connmark restore — only act when Tailscale mark band is set, then
# copy full ct mark to skb (coexist with e.g. GL policy marks at 0x8000).
#
# Before: meta mark set ct mark & TailscaleFwmarkMask (zeros other skb bits; always runs).
# After:  ct mark & mask != 0, then meta mark set ct mark. OUTPUT save rule unchanged.
#
Index: tailscale-1.96.4/util/linuxfw/nftables_runner.go
===================================================================
--- tailscale-1.96.4.orig/util/linuxfw/nftables_runner.go
+++ tailscale-1.96.4/util/linuxfw/nftables_runner.go
@@ -1960,7 +1960,11 @@
 }
 
 // makeConnmarkRestoreExprs creates nftables expressions to restore mark from conntrack.
-// Implements: ct state established,related ct mark & 0xff0000 != 0 meta mark set ct mark & 0xff0000
+// Implements: ct state established,related ct mark & TailscaleFwmarkMask != 0 meta mark set ct mark
+//
+// When the Tailscale field in ct is zero, the rule does not run, so we do not assign
+// skb mark := 0 and wipe vendor bits (e.g. GL policy routing 0x8000). When non-zero,
+// we copy the full ct mark to the packet (not only the masked band).
 func makeConnmarkRestoreExprs() []expr.Any {
 	return []expr.Any{
 		// Load conntrack state into register 1
@@ -1996,7 +2000,17 @@
 			Mask:           getTailscaleFwmarkMask(),
 			Xor:            []byte{0x00, 0x00, 0x00, 0x00},
 		},
-		// Set packet mark from register 1
+		// Skip when the Tailscale band in ct is zero.
+		&expr.Cmp{
+			Op:       expr.CmpOpNeq,
+			Register: 1,
+			Data:     []byte{0, 0, 0, 0},
+		},
+		// Reload full ct mark, then set skb mark (meta mark set ct mark).
+		&expr.Ct{
+			Register: 1,
+			Key:      expr.CtKeyMARK,
+		},
 		&expr.Meta{
 			Key:            expr.MetaKeyMARK,
 			SourceRegister: true,
